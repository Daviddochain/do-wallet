server {
    listen 8080;
    listen [::]:8080;
    server_name _ do-wallet.com www.do-wallet.com;

    root /opt/dochain-wallet/current/frontend;
    index index.html;

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_comp_level 5;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/xml
        image/svg+xml;

    access_log /var/log/nginx/dochain-wallet.access.log;
    error_log /var/log/nginx/dochain-wallet.error.log;

    location ~ ^/station-assets/api/lcd/[^/]+/terra/alliances/delegations {
        default_type application/json;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        return 200 '{"delegations":[],"pagination":{"next_key":null,"total":"0"}}';
    }

    location ~ ^/station-assets/api/lcd/[^/]+/terra/alliances/rewards {
        default_type application/json;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        return 200 '{"rewards":[],"total":[]}';
    }

    location ~ ^/station-assets/api/lcd/[^/]+/terra/alliances/params$ {
        default_type application/json;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        return 200 '{"params":{}}';
    }

    location ~ ^/station-assets/api/lcd/[^/]+/terra/alliances(?:/.*)?$ {
        default_type application/json;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        return 200 '{"alliances":[],"pagination":{"next_key":null,"total":"0"}}';
    }

    location /station-assets/api/ {
        proxy_pass http://127.0.0.1:3001/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header If-None-Match "";
        proxy_set_header If-Modified-Since "";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        proxy_connect_timeout 30s;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    location /station-assets/lcd/ {
        proxy_pass http://127.0.0.1:3001/lcd/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 30s;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    location /station-assets/ {
        alias /opt/dochain-wallet/current/station-assets/;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "public, max-age=300" always;
        try_files $uri =404;
    }

    location /extension/ {
        alias /opt/dochain-wallet/current/extension/;
        try_files $uri $uri/ =404;
    }

    location = /extension.zip {
        alias /opt/dochain-wallet/current/extension.zip;
        add_header Content-Type application/zip;
    }

    location = /blacklist.json {
        add_header Access-Control-Allow-Origin "*" always;
        add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
        add_header Access-Control-Allow-Headers "Content-Type, Authorization" always;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        try_files /blacklist.json =404;
    }



    location = / {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        add_header Clear-Site-Data '"cache"' always;
        try_files /index.html =404;
    }

    location = /index.html {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        add_header Clear-Site-Data '"cache"' always;
        try_files /index.html =404;
    }

    location = /asset-manifest.json {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        try_files /asset-manifest.json =404;
    }

    location ~ ^/static/(js|css)/(dochain|do-wallet|website|portfolio|onramper|quarantine|main\.do-validatoredit).*\.(js|css)$ {
        gzip_static on;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        try_files $uri =404;
    }

    location /static/ {
        gzip_static on;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        try_files $uri =404;
    }

    location / {
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" always;
        add_header Clear-Site-Data '"cache"' always;
        try_files $uri $uri/ /index.html;
    }

    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/do-wallet.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/do-wallet.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}

